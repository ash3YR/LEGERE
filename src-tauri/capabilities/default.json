{
  "$schema": "https://raw.githubusercontent.com/nicovank/tauri-v2-schema/v2/schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-read-file",
    "fs:allow-exists",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "dialog:allow-save",
    "core:window:allow-set-fullscreen",
    "core:window:allow-is-fullscreen",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "**"
        }
      ]
    },
    "shell:default"
  ]
}